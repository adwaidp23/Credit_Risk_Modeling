models/*.h5
models/*.pt
models/*.onnx

# ─── Generated Data Files ─────────────────────────────────────────────────────
data/audit_logs.db

# ─── Generated Output Files ───────────────────────────────────────────────────
# outputs/ and reports/figures/ are committed for portfolio visibility

# ─── Logs & Runtime ───────────────────────────────────────────────────────────
*.log
logs/
*.sqlite
*.db

# ─── OS-Specific ──────────────────────────────────────────────────────────────
