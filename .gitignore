# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# ─── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
